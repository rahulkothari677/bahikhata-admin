# =====================================================================
# BahiKhata Pro Admin Panel — Environment Variables
# =====================================================================
# This admin panel is COMPLETELY SEPARATE from the main app.
# It uses READ-ONLY database access for security (defense in depth).
#
# DO NOT use the same credentials as the main app. Create a separate
# read-only database user (see DEPLOYMENT.md for SQL commands).
# =====================================================================

# Database (READ-ONLY user — create this in your Neon/Vercel Postgres console)
# See DEPLOYMENT.md for instructions on creating the admin_readonly user.
#
# IMPORTANT FOR NEON FREE TIER:
# Neon auto-suspends after inactivity. To prevent "Error { kind: Close }"
# connection errors, add ?connection_limit=5&pool_timeout=10 to your URL:
DATABASE_URL="postgresql://admin_readonly:PASSWORD@host/database?sslmode=require&connection_limit=5&pool_timeout=10"

# NextAuth (admin panel — SEPARATE secret from main app!)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-new-secret-here-different-from-main-app"
NEXTAUTH_URL="https://admin.bahikhata.pro"

# Founder emails — ONLY these emails can create admin accounts or log in
# Comma-separated, lowercase
FOUNDER_EMAILS="rahulkothari677@gmail.com"

# IP Allowlist (optional but recommended) — comma-separated CIDR or IPs
# If set, only these IPs can access the admin panel.
# Example: "103.21.0.0/22,49.205.0.0/16"
# Leave empty to allow all IPs (not recommended for production)
ADMIN_IP_ALLOWLIST=""

# Main app API (for write operations that need to go through the main app)
# The admin app calls the main app's API for actions like changing user plans.
# This shared secret MUST match the ADMIN_API_SECRET in the main app's env vars.
ADMIN_API_SECRET="generate-another-secret-here"
MAIN_APP_URL="https://bahikhata-pro.vercel.app"

# AI Provider pricing (for AI usage cost dashboard — display only)
# These match the main app's pricing so cost calculations are accurate.
GEMINI_INPUT_PER_1M="0.30"
GEMINI_OUTPUT_PER_1M="2.50"
USD_TO_INR="84.5"


# 🔒 AUDIT FIX V5: Missing env vars

# Cron Secret — required for cron endpoints in production.
# If unset, cron endpoints will reject unauthenticated requests (fail-closed).
# Generate with: openssl rand -base64 32
CRON_SECRET=""

# Read-only database URL — used by the SQL runner (database-admin.ts).
# 🔒 AUDIT FIX V6 SC4: Create a read-only Postgres role and use its connection
# string here. In production, the SQL console (/api/admin/database/query) now
# FAILS CLOSED (returns 503) if this is not set — it no longer falls back to
# the read-write DATABASE_URL. This is a defense-in-depth requirement from
# the V6 auditor: an endpoint that can read every user's financial data must
# never run on a read-write connection without explicit configuration.
#
# SQL to create the role (run in Neon SQL editor):
#   CREATE ROLE admin_readonly WITH LOGIN PASSWORD 'your-strong-password' CONNECTION LIMIT 5;
#   GRANT CONNECT ON DATABASE neondb TO admin_readonly;
#   GRANT USAGE ON SCHEMA public TO admin_readonly;
#   GRANT SELECT ON ALL TABLES IN SCHEMA public TO admin_readonly;
#   ALTER DEFAULT PRIVILEGES IN SCHEMA public GRANT SELECT ON TABLES TO admin_readonly;
#
# Statement timeout (recommended): append &statement_timeout=10000 to the URL
# so a runaway SELECT can't hog the connection for more than 10 seconds.
# (Prisma may not pass this through — the SQL console also enforces a JS-side
# 10s timeout via withTimeout() as a belt-and-suspenders measure.)
#
# Connection string format:
#   postgresql://admin_readonly:PASSWORD@host/database?sslmode=require&connection_limit=5&pool_timeout=10
READONLY_DATABASE_URL=""

# =====================================================================
# Upstash Redis (for admin login rate limiting)
# =====================================================================
# 🔒 V9 2.4: Required for Redis-backed admin login rate limiting.
# Without these, falls back to in-memory (per-instance, resets on cold start).
# Use the SAME Upstash Redis instance as the main app (shared rate limit state).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
