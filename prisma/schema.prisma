// BahiKhata Pro — India's Best Ledger App
// Database schema for shop owners: products, parties, transactions, GST, etc.
// Multi-tenant: every model has userId for data isolation

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== USERS (Authentication) ====================
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String    // hashed with bcrypt
  phone         String?   // for future phone OTP
  emailVerified DateTime? // for future email verification
  image         String?   // profile picture URL
  role          String    @default("owner") // owner | staff
  ownerId       String?   // if staff, links to the owner's account
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Staff permissions — JSON object controlling which modules staff can access.
  permissions   Json?

  // Subscription / plan
  cancelledAt   DateTime?
  plan          String    @default("free") // free | pro | elite
  renewsAt      DateTime?
  trialEndsAt   DateTime?

  // Relations
  products      Product[]
  parties       Party[]
  transactions  Transaction[]
  payments      Payment[]
  settings      Setting[]
  auditLogs     AuditLog[]
  referralsMade Referral[] @relation("Referral_referrerIdToUser")
  referralReceived Referral? @relation("Referral_referredIdToUser")
  subscriptions Subscription[]
  usageTracking  UsageTracking[]
  shops         Shop[]
  scanComparisons ScanComparison[]
  aiUsageLogs    AiUsageLog[]
  supportTickets SupportTicket[]
  npsFeedback   NpsFeedback[]
}

// ==================== SHOPS (Multi-shop support) ====================
// Each owner can have multiple shops. Products, transactions, parties
// can be tagged with a shopId. When null, shows in all shops (backward compatible).
model Shop {
  id          String   @id @default(cuid())
  userId      String   // owner of this shop
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String   // e.g. "Sharma Kirana Store"
  gstin       String?
  address     String?
  phone       String?
  state       String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

// ==================== PRODUCTS / INVENTORY ====================
model Product {
  id                String   @id @default(cuid())
  userId            String   // owner of this product
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shopId            String?  // multi-shop: null = all shops (backward compatible)
  name              String
  sku               String?
  hsn               String?  // HSN/SAC code for GST
  category          String?
  unit              String   @default("pcs") // pcs, kg, ltr, m, box
  purchasePrice     Float    @default(0)  // price at which shop owner buys
  salePrice         Float    @default(0)  // price at which shop owner sells
  mrp               Float?   // MRP printed on product
  gstRate           Float    @default(0)  // 0, 5, 12, 18, 28
  openingStock      Float    @default(0)
  lowStockThreshold Float    @default(5)
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  transactionItems  TransactionItem[]

  // Unique SKU per user (not globally)
  @@unique([userId, sku])
  // Performance: list products per user, search by name within user
  @@index([userId, name])
  @@index([userId, category])
  @@index([userId, shopId])
}

// ==================== PARTIES (Customers & Suppliers) ====================
model Party {
  id              String   @id @default(cuid())
  userId          String   // owner of this party
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shopId          String?  // multi-shop: null = all shops (backward compatible)
  name            String
  type            String   @default("customer") // customer | supplier | both
  phone           String?
  email           String?
  gstin           String?  // GST Identification Number
  address         String?
  state           String?  // for intra/inter state GST
  openingBalance  Float    @default(0) // positive = they owe us; negative = we owe them
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  transactions    Transaction[]
  payments        Payment[]
}

// ==================== TRANSACTIONS (Sales, Purchases, Income, Expense) ====================
model Transaction {
  id             String   @id @default(cuid())
  userId         String   // owner of this transaction
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shopId         String?  // multi-shop: null = all shops (backward compatible)
  invoiceNo      String?  // bill/invoice number from bill
  type           String   // sale | purchase | income | expense
  partyId        String?  // customer for sale, supplier for purchase
  party          Party?   @relation(fields: [partyId], references: [id])
  date           DateTime @default(now())
  subtotal       Float    @default(0)  // before tax & discount
  discountAmount Float    @default(0)
  cgst           Float    @default(0)
  sgst           Float    @default(0)
  igst           Float    @default(0)
  totalAmount    Float    @default(0)  // final payable
  paidAmount     Float    @default(0)  // amount actually paid
  paymentMode    String   @default("cash") // cash | upi | card | bank | credit
  isInterState   Boolean  @default(false)
  notes          String?
  // For income/expense (no items)
  category       String?  // e.g. rent, salary, electricity for expenses; commission etc for income
  // Payee info for income/expense (who you paid or received from)
  payeeName      String?  // name of person you paid / received from
  payeePhone     String?  // mobile number of payee
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  items          TransactionItem[]

  // Auto-computed gross profit when type=sale
  grossProfit    Float    @default(0)

  // Performance: list transactions per user filtered by date and/or type
  // Used by: dashboard, ledger (sales/purchases), reports
  @@index([userId, date])
  @@index([userId, type, date])
  @@index([userId, partyId])
}

model TransactionItem {
  id             String   @id @default(cuid())
  transactionId  String
  transaction    Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  productId      String?
  product        Product?  @relation(fields: [productId], references: [id])
  productName    String   // snapshot of name at time of transaction
  quantity       Float    @default(1)
  unitPrice      Float    @default(0)  // price per unit (sale or purchase)
  gstRate        Float    @default(0)
  discountAmount Float    @default(0)
  total          Float    @default(0)  // qty * unitPrice - discount + gst

  createdAt      DateTime @default(now())
}

// ==================== PAYMENTS (separate from transaction totals) ====================
model Payment {
  id          String   @id @default(cuid())
  userId      String   // owner of this payment
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  partyId     String
  party       Party    @relation(fields: [partyId], references: [id])
  amount      Float
  date        DateTime @default(now())
  mode        String   @default("cash") // cash | upi | card | bank
  type        String   @default("received") // received (from customer) | paid (to supplier)
  notes       String?
  createdAt   DateTime @default(now())
}

// ==================== APP SETTINGS (per user) ====================
model Setting {
  id        String   @id @default(cuid())
  userId    String   @unique // one setting per user
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shopName  String   @default("My Shop")
  ownerName String?
  address   String?
  phone     String?
  gstin     String?
  state     String?
  email     String?
  currency  String   @default("INR")
  language  String   @default("en")
  // Privacy: when true, profit figures are hidden from all UI (dashboard,
  // ledger, transaction detail). Data is still calculated and stored —
  // only the display is hidden. Owner controls this; staff inherits.
  hideProfit Boolean @default(false)
}

// ==================== ANNOUNCEMENTS (broadcast messages) ====================
model Announcement {
  id        String    @id
  title     String
  message   String
  type      String    @default("info") // info | warning | success | promo
  link      String?
  isActive  Boolean   @default(true)
  startsAt  DateTime  @default(now())
  endsAt    DateTime?
  createdAt DateTime  @default(now())
  createdBy String?

  @@index([isActive, startsAt, endsAt])
}

// ==================== FEATURE FLAGS (remote kill switches) ====================
model FeatureFlag {
  id          String   @id
  key         String   @unique
  enabled     Boolean  @default(true)
  label       String
  description String?
  updatedAt   DateTime
  updatedBy   String?

  @@index([enabled])
}

// ==================== REFERRALS (refer 3 = 1 year free Pro) ====================
model Referral {
  id          String    @id
  referrerId  String
  referredId  String?   @unique
  code        String    @unique
  status      String    @default("pending") // pending | completed | rewarded
  rewardGiven Boolean   @default(false)
  createdAt   DateTime  @default(now())
  completedAt DateTime?
  referrer    User      @relation("Referral_referrerIdToUser", fields: [referrerId], references: [id], onDelete: Cascade)
  referred    User?     @relation("Referral_referredIdToUser", fields: [referredId], references: [id])

  @@index([referredId])
  @@index([referrerId, status])
}

// ==================== SUBSCRIPTIONS (Razorpay payments) ====================
model Subscription {
  id             String   @id
  userId         String
  plan           String   // pro | elite
  status         String   @default("active") // active | cancelled | expired
  amount         Float
  paymentMode    String   @default("razorpay")
  paymentId      String?
  subscriptionId String?
  startDate      DateTime @default(now())
  endDate        DateTime
  createdAt      DateTime @default(now())
  User           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([userId, status])
}

// ==================== USAGE TRACKING (plan limits) ====================
model UsageTracking {
  id           String   @id
  userId       String
  month        String   // YYYY-MM format
  transactions Int      @default(0)
  aiScans      Int      @default(0)
  voiceParses  Int      @default(0)
  products     Int      @default(0)
  updatedAt    DateTime
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
  @@index([userId, month])
}

// ==================== AUDIT LOG (security & compliance) ====================
// Track every important action: logins, data exports, deletes, role changes.
// Used for: security forensics, compliance (DPDP Act), dispute resolution.
model AuditLog {
  id         String   @id @default(cuid())
  userId     String?  // user who performed the action (null = unauthenticated attempt)
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String   // login_success | login_failure | logout | data_export | data_delete | role_change | settings_update | etc.
  entityType String?  // product | party | transaction | setting | user | staff
  entityId   String?  // ID of the affected entity
  ip         String?  // IP address of the actor
  userAgent  String?  // browser/device info
  metadata   Json?    // any extra context (what changed, what was exported, etc.)
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
}

// ==================== AI SCAN COMPARISONS ====================
// Stores results of side-by-side AI provider tests. Each record is one
// bill image scanned by 1-3 providers (Gemini, OpenAI, Groq). Admins use
// the /settings/ai-comparison page to compare accuracy and pick the best.
model ScanComparison {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // The bill image that was scanned
  imageName     String?  // filename or label, if user provided one
  imagePreview  String   // base64 thumbnail (max ~50KB) for display in history

  // Bill type the user said it was
  billType      String   @default("purchase") // sale | purchase

  // Results from each provider (null if that provider wasn't tested)
  geminiResult  Json?    // { success, parsed, error, durationMs, tokensUsed }
  openaiResult  Json?
  groqResult    Json?

  // Ground truth (what the user manually entered as the correct answer)
  groundTruth   Json?    // { sellerName, totalAmount, itemsCount, items: [...] }

  // Computed scores per provider (0-100, null if not tested or no ground truth)
  geminiScore   Float?
  openaiScore   Float?
  groqScore     Float?

  createdAt     DateTime @default(now())

  @@index([userId, createdAt])
  @@index([createdAt])
}

// ==================== AI USAGE LOG (cost tracking) ====================
// Every AI call (scan-bill, voice-parse) gets logged here with exact token
// counts and calculated cost. Used by the /settings/ai-usage dashboard to
// show the founder exactly how much each feature costs to run.
model AiUsageLog {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  feature       String   // 'scan-bill' | 'voice-parse' | 'scan-compare'
  provider      String   // 'gemini' | 'openai' | 'groq' | 'vlm' | 'zai-sdk'
  model         String   // e.g. 'gemini-2.5-flash', 'llama-4-scout-17b-16e-instruct'

  // Token counts from the AI provider's response
  inputTokens   Int      @default(0)
  outputTokens  Int      @default(0)
  totalTokens   Int      @default(0)

  // Cost in INR (calculated at time of call using current pricing)
  // Stored per-call so historical costs are preserved even if prices change
  costInr       Float    @default(0)

  // Performance + result
  durationMs    Int      @default(0)
  success       Boolean  @default(true)
  errorMessage  String?  // null if success, error text if failed

  createdAt     DateTime @default(now())

  @@index([userId, createdAt])
  @@index([feature, createdAt])
  @@index([provider, createdAt])
}


// ==================== ADMIN USERS (admin panel auth) ====================
// SEPARATE from main app users. Admin accounts have their own credentials,
// 2FA secrets, and audit trail. This table is ONLY used by the admin app.
//
// Security: Admin accounts are created MANUALLY (no public signup).
// Only founder emails are allowed. 2FA is mandatory.
model AdminUser {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  password      String    // hashed with bcrypt
  role          String    @default("admin") // founder | admin | viewer
  totpSecret    String?   // TOTP 2FA secret (encrypted at rest)
  totpEnabled   Boolean   @default(false)
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  lastLoginIp   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  adminActions  AdminAction[]

  @@index([email])
  @@index([isActive])
}

// ==================== ADMIN ACTIONS (audit trail) ====================
// Every action performed in the admin panel is logged here.
// Used for: security forensics, compliance, dispute resolution.
// This is SEPARATE from the main app's AuditLog table — admin actions
// are more sensitive and need their own audit trail.
model AdminAction {
  id            String   @id @default(cuid())
  adminId       String
  admin         AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)
  action        String   // user_plan_change | user_ban | feature_toggle | data_export | etc.
  targetType    String?  // user | feature_flag | subscription | etc.
  targetId      String?  // ID of the affected entity
  description   String   // human-readable description
  metadata      Json?    // before/after values, etc.
  ip            String?
  userAgent     String?
  createdAt     DateTime @default(now())

  @@index([adminId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId])
}

// ==================== SUPPORT TICKETS ====================
// Users report issues from the main app → admin resolves them here.
// Priority levels: low, medium, high, urgent.
// Status flow: open → in_progress → resolved → closed.
model SupportTicket {
  id          String    @id @default(cuid())
  userId      String    // user who submitted the ticket
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject     String
  message     String
  category    String    @default("general") // general | bug | billing | feature_request | account
  priority    String    @default("medium") // low | medium | high | urgent
  status      String    @default("open") // open | in_progress | resolved | closed
  assignedTo  String?   // admin email who's handling it

  // Admin response
  response    String?
  resolvedAt  DateTime?
  resolvedBy  String?   // admin email who resolved it

  // Metadata
  userEmail   String?
  userAgent   String?
  appVersion  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, priority, createdAt])
  @@index([userId, createdAt])
  @@index([assignedTo, status])
}

// ==================== FEATURE FLAG RULES ====================
// Advanced feature flag targeting rules. Instead of just on/off,
// you can target specific users, plans, or percentages.
// Examples:
//   - "Enable AI scanner for 50% of Pro users"
//   - "Enable new dashboard for users in Maharashtra"
//   - "Disable voice entry for users on Android < 10"
model FeatureFlagRule {
  id            String   @id @default(cuid())
  flagKey       String   // references FeatureFlag.key
  ruleType      String   // all | plan | percentage | user_list | location
  ruleValue     String   // JSON: { plans: ["pro"], percentage: 50, userIds: [], states: [] }
  enabled       Boolean  @default(true)
  priority      Int      @default(0) // higher = evaluated first
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([flagKey, enabled, priority])
}

// ==================== NPS FEEDBACK ====================
model NpsFeedback {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  score       Int      // 0-10 (0=worst, 10=best)
  feedback    String?  // optional text feedback
  category    String?  // auto-categorized: promoter | passive | detractor
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@index([score])
}

// ==================== DAILY STATS (pre-computed KPIs) ====================
// Instead of running count()/aggregate() on millions of rows on every
// dashboard load, a background job computes these once per day and stores
// them here. The dashboard reads 1 row per day = instant load.
//
// This is THE most important table for scalability. Without it, the
// dashboard would timeout at 100K+ users.
model DailyStats {
  id              String   @id @default(cuid())
  date            DateTime @unique  // the day this record represents (midnight UTC)

  // User metrics
  totalUsers      Int      @default(0)  // cumulative total users
  newUsers        Int      @default(0)  // new signups this day
  activeUsers     Int      @default(0)  // DAU (users active this day)
  payingUsers     Int      @default(0)  // cumulative paying users

  // Revenue metrics
  mrr             Float    @default(0)  // monthly recurring revenue (end of day)
  newMrr          Float    @default(0)  // new MRR added this day
  churnedMrr      Float    @default(0)  // MRR lost this day
  arr             Float    @default(0)  // annual run rate (mrr * 12)

  // Transaction metrics
  totalGmv        Float    @default(0)  // gross merchandise value (sum of all sales)
  totalTxns       Int      @default(0)  // total transactions this day
  salesCount      Int      @default(0)  // sales this day
  purchasesCount  Int      @default(0)  // purchases this day

  // AI metrics
  aiCalls         Int      @default(0)  // total AI calls this day
  aiCostInr       Float    @default(0)  // AI cost this day (INR)
  aiScans         Int      @default(0)  // bill scans this day
  voiceParses     Int      @default(0)  // voice entries this day

  // Computed at
  computedAt      DateTime @default(now())

  @@index([date])
}

// ==================== USER SEGMENTS (pre-computed) ====================
// Instead of calculating segments on-the-fly (N+1 queries), a background
// job computes segment membership and stores it here. The segments page
// reads from this table = instant load, scales to millions.
model UserSegmentCache {
  id          String   @id @default(cuid())
  userId      String
  segmentId   String   // power_users, whales, at_risk, etc.
  computedAt  DateTime @default(now())

  @@unique([userId, segmentId])
  @@index([segmentId])
  @@index([userId])
}

// ==================== CREDIT SCORE CACHE ====================
// Instead of computing credit scores on-the-fly (N+1 queries), a
// background job computes them daily and caches here.
model CreditScoreCache {
  id              String   @id @default(cuid())
  userId          String   @unique
  score           Int      // 300-900
  band            String   // excellent | good | fair | poor
  avgMonthlySales Float    @default(0)
  totalSales6Mo   Float    @default(0)
  activeMonths    Int      @default(0)
  collectionRate  Float    @default(0)
  businessAgeDays Int      @default(0)
  productCount    Int      @default(0)
  partyCount      Int      @default(0)
  hasGstData      Boolean  @default(false)
  recommendation  String?
  computedAt      DateTime @default(now())

  @@index([score])
  @@index([band])
}

// ==================== NOTIFICATION TEMPLATES ====================
// Reusable templates for SMS, Email, and Push notifications.
// Variables use {{double_curly_brace}} syntax (e.g. {{userName}}, {{amount}}).
// Used by: Campaign Management, Multi-channel Notifications, transactional sends.
// Created by admin, versioned (version field), with category for organization.
model NotificationTemplate {
  id          String   @id @default(cuid())
  name        String                          // human-readable name (e.g. "Payment Reminder")
  category    String   @default("general")   // general | payment | onboarding | churn | promotional
  channel     String                          // sms | email | push
  subject     String?                          // email subject (null for sms/push)
  body        String   @db.Text               // template body with {{variables}}
  variables   String   @default("[]") @db.Text // JSON array of variable names: ["userName", "amount"]
  language    String   @default("en")         // en | hi | bilingual
  status      String   @default("draft")      // draft | active | archived
  version     Int      @default(1)            // bumped on each edit
  createdBy   String?                          // admin user ID
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([channel, status])
  @@index([category, status])
  @@index([status])
}

// ==================== NOTIFICATION LOG ====================
// Logs every notification send attempt (SMS/Email/Push).
// Used for: audit trail, delivery analytics, retry logic, compliance.
// A notification can be: sent (delivered), failed (provider error),
// pending (queued), or skipped (dry-run mode / user opted out).
model NotificationLog {
  id            String   @id @default(cuid())
  // Recipient
  userId        String?                          // null = anonymous/bulk recipient
  recipient     String                            // phone (SMS) or email (Email) or deviceToken (Push)
  // Template used (optional — direct sends don't use templates)
  templateId    String?
  templateName  String?                           // snapshot of template name at send time
  // Content snapshot (what was actually sent, after variable substitution)
  channel       String                            // sms | email | push
  subject       String?
  body          String   @db.Text
  // Delivery status
  status        String   @default("pending")     // pending | sent | failed | skipped
  provider      String?                           // msg91 | resend | fcm | dry-run
  providerMessageId String?                       // ID returned by provider (for tracking)
  errorMessage  String?                           // null if success, error text if failed
  // Metadata
  sentBy        String?                           // admin user ID
  sentAt        DateTime @default(now())
  // Category for filtering (mirrors template category)
  category      String   @default("general")

  @@index([userId, sentAt])
  @@index([channel, status, sentAt])
  @@index([status, sentAt])
  @@index([sentAt])
}

// ==================== CAMPAIGNS ====================
// A campaign = a sequence of scheduled notifications sent to a target audience
// over time. Each campaign has 1+ steps, each step uses a notification template.
//
// Example: "Onboarding Drip"
//   Step 1: Day 0  → Welcome SMS (template: welcome_sms)
//   Step 2: Day 3  → Tips Email (template: tips_email)
//   Step 3: Day 7  → Discount Push (template: discount_push)
//   Step 4: Day 14 → Win-back SMS (template: winback_sms)
//
// Target audience can be:
//   - A segment ID (uses pre-computed UserSegmentCache)
//   - A manual list of user IDs (JSON array)
//
// Status lifecycle: draft → scheduled → running → completed | cancelled | paused
model Campaign {
  id              String   @id @default(cuid())
  name            String
  description     String?  @db.Text
  status          String   @default("draft")   // draft | scheduled | running | paused | completed | cancelled

  // Target audience
  targetSegmentId String?                          // null if using manual userIds
  targetUserIds   String   @default("[]") @db.Text // JSON array of user IDs (if no segment)

  // Schedule
  startAt         DateTime?                        // when to start sending step 1
  endAt           DateTime?                        // computed: startAt + sum(step delays)

  // Stats (updated by background job after each step)
  totalRecipients Int      @default(0)
  totalSent       Int      @default(0)
  totalFailed     Int      @default(0)
  totalSkipped    Int      @default(0)
  currentStep     Int      @default(0)             // which step is currently running (0 = not started)

  // Metadata
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  startedAt       DateTime?
  completedAt     DateTime?

  steps           CampaignStep[]

  @@index([status, startAt])
  @@index([createdBy])
}

model CampaignStep {
  id              String   @id @default(cuid())
  campaignId      String
  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  stepNumber      Int                                // 1-indexed (step 1, 2, 3...)
  templateId      String                             // NotificationTemplate ID
  templateName    String?                            // snapshot at send time

  // Delay AFTER campaign startAt (in minutes)
  // Step 1: delayMinutes=0 (send immediately on start)
  // Step 2: delayMinutes=4320 (3 days × 1440 min/day)
  // Step 3: delayMinutes=10080 (7 days)
  delayMinutes    Int      @default(0)

  // Status of this step
  status          String   @default("pending")      // pending | running | sent | failed | skipped
  scheduledAt     DateTime?                          // computed: campaign.startAt + delayMinutes
  sentAt          DateTime?

  // Stats for this step
  recipientCount  Int      @default(0)
  sentCount       Int      @default(0)
  failedCount     Int      @default(0)
  skippedCount    Int      @default(0)

  errorMessage    String?

  @@index([campaignId, stepNumber])
  @@index([status, scheduledAt])
}

// ==================== STATUS PAGE / INCIDENTS ====================
// Public-facing status page data. NO AUTH REQUIRED to read.
// Used by /status page (investor + user trust signal).
//
// An incident has:
//   - A title (e.g. "Database connectivity issues")
//   - A severity (minor | major | critical | maintenance)
//   - A status (investigating | identified | monitoring | resolved)
//   - A service affected (api | database | ai_providers | payments | all)
//   - A timeline of updates (IncidentUpdate[])
//   - startedAt + resolvedAt timestamps
model Incident {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  severity    String   @default("minor")     // minor | major | critical | maintenance
  status      String   @default("investigating") // investigating | identified | monitoring | resolved
  service     String   @default("all")       // api | database | ai_providers | payments | all

  startedAt   DateTime @default(now())
  resolvedAt  DateTime?

  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  updates     IncidentUpdate[]

  @@index([status, startedAt])
  @@index([service, status])
}

model IncidentUpdate {
  id          String   @id @default(cuid())
  incidentId  String
  incident    Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  message     String   @db.Text
  status      String                                   // snapshot of incident status at this update
  createdBy   String?
  createdAt   DateTime @default(now())

  @@index([incidentId, createdAt])
}

// ==================== ANOMALY DETECTION ====================
// Auto-detected anomalies from metric analysis (z-score based).
// A background job (or manual trigger) compares recent metric values
// to a 30-day baseline. If the z-score exceeds a threshold, an anomaly
// is created here for admin review.
//
// Lifecycle: open → acknowledged → resolved (admin marks false-positive or fixed)
model Anomaly {
  id            String   @id @default(cuid())
  metric        String                          // new_signups | revenue | ai_cost | failed_logins | etc.
  metricLabel   String                          // human-readable label
  direction     String                          // spike | drop
  severity      String   @default("medium")     // low | medium | high | critical
  status        String   @default("open")       // open | acknowledged | resolved

  // Statistical data
  currentValue  Float                            // the anomalous value
  baselineValue Float                            // expected value (mean of baseline)
  baselineStdDev Float                           // standard deviation of baseline
  zScore        Float                            // (current - baseline) / stdDev
  baselineDays  Int      @default(30)            // how many days used for baseline

  // Time window
  detectedAt    DateTime @default(now())
  windowStart   DateTime                         // start of the anomalous period
  windowEnd     DateTime                         // end of the anomalous period

  // Admin response
  acknowledgedBy String?
  acknowledgedAt DateTime?
  resolvedBy     String?
  resolvedAt     DateTime?
  adminNote      String?  @db.Text               // admin's note on resolution

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status, detectedAt])
  @@index([metric, detectedAt])
  @@index([detectedAt])
}

// ==================== CONFIGURABLE FRAUD RULES ====================
// Admin-defined rules that auto-detect suspicious activity.
// Each rule has a metric, condition, threshold, and time window.
// When a user's activity matches a rule, a FraudAlert is created.
//
// Example rules:
//   - "Flag users with > 50 transactions in 1 hour"
//   - "Flag users with > ₹1,00,000 total sales in 24 hours"
//   - "Flag users with > 20 AI calls in 1 hour"
//   - "Flag users who created account < 1 hour ago AND have > 10 transactions"
model FraudRule {
  id              String   @id @default(cuid())
  name            String
  description     String?  @db.Text

  // What to measure
  metric          String                          // transaction_count | transaction_amount | ai_call_count | login_failure_count | new_user_with_activity
  // Condition
  operator        String                          // gt | gte | lt | lte | eq
  threshold       Float

  // Time window in minutes (e.g. 60 = 1 hour, 1440 = 24 hours)
  // null = all-time (no window)
  windowMinutes   Int?

  // Optional: only apply to users created within X minutes (for "new user" rules)
  userAgeMinutes  Int?

  // Status
  enabled         Boolean  @default(true)
  severity        String   @default("medium")     // low | medium | high | critical

  // Metadata
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  alerts          FraudAlert[]

  @@index([enabled, metric])
}

model FraudAlert {
  id              String   @id @default(cuid())
  ruleId          String
  rule            FraudRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  // Who triggered it
  userId          String
  userName        String?
  userEmail       String?

  // What was detected
  metricValue     Float                            // the value that triggered the alert
  threshold       Float                            // the rule's threshold (snapshot)

  // Status
  status          String   @default("open")       // open | acknowledged | resolved | false_positive
  adminNote       String?  @db.Text

  // Metadata
  detectedAt      DateTime @default(now())
  acknowledgedBy  String?
  acknowledgedAt  DateTime?
  resolvedBy      String?
  resolvedAt      DateTime?

  @@index([status, detectedAt])
  @@index([ruleId, detectedAt])
  @@index([userId, detectedAt])
}

// ==================== PARTNER MANAGEMENT ====================
// Directory of business partners (NBFCs, FMCG companies, fintechs) for
// the lending and data-monetization pipeline.
//
// Partner types:
//   - nbfc: Non-Banking Financial Company (lending — receives credit-scored leads)
//   - fmcg: Fast-Moving Consumer Goods (receives supplier intelligence data)
//   - fintech: Other fintech integrations (payments, accounting, etc.)
//   - other: Other partner types
//
// Revenue model:
//   - NBFC: ₹200/₹150/₹100 per lead by credit band (excellent/good/fair)
//   - FMCG: ₹50K-₹5L per intelligence report
//   - Fintech: Revenue share % (revenueSharePct field)
model Partner {
  id                  String   @id @default(cuid())
  name                String
  type                String   @default("nbfc")     // nbfc | fmcg | fintech | other
  status              String   @default("onboarding") // onboarding | active | inactive | terminated

  // Contact info
  contactName         String?
  contactEmail        String?
  contactPhone        String?
  website             String?

  // Integration
  apiBaseUrl          String?                          // e.g. https://api.partner.com
  webhookUrl          String?                          // where we send lead notifications
  revenueSharePct     Float    @default(0)             // 0-100, for fintech revenue share

  // Stats (updated when leads are sent)
  totalLeadsSent      Int      @default(0)
  totalRevenueShared  Float    @default(0)             // in INR

  // Contract
  contractStartAt     DateTime?
  contractEndAt       DateTime?
  notes               String?  @db.Text

  // Metadata
  createdBy           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  apiKeys             ApiKey[]
  webhookEndpoints    WebhookEndpoint[]

  @@index([type, status])
  @@index([status])
}

// ==================== API KEYS (Partner Authentication) ====================
// API keys issued to partners for programmatic access to our API.
// SECURITY: We store only the SHA-256 hash of the key, never the raw key.
// The raw key is shown ONCE on creation — admin must save it securely.
//
// Scopes define what the key can access:
//   - read_leads: GET lead data (credit scores for lending)
//   - write_leads: POST lead status updates (approved/rejected)
//   - read_analytics: GET aggregate analytics (market intelligence)
//   - read_users: GET user data (anonymized)
//   - read_revenue: GET revenue/share data
//   - admin: full access (use sparingly)
model ApiKey {
  id            String    @id @default(cuid())
  partnerId     String?                            // null = internal/admin key (not tied to partner)
  partner       Partner?  @relation(fields: [partnerId], references: [id], onDelete: SetNull)

  name          String                             // human-readable label (e.g. "Bajaj Production Key")
  keyHash       String   @unique                   // SHA-256 hash of the raw key (never store raw)
  keyPrefix     String                             // first 12 chars of raw key (for display: bkh_live_abc1...)
  scopes        String   @default("[]") @db.Text   // JSON array of scope strings

  status        String   @default("active")        // active | revoked | expired
  expiresAt     DateTime?                          // null = never expires

  // Usage tracking
  lastUsedAt    DateTime?
  usageCount    Int      @default(0)

  // Metadata
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([partnerId, status])
  @@index([status])
  @@index([keyHash])
}

// ==================== WEBHOOK ENDPOINTS ====================
// Partner webhook endpoints where we POST event notifications.
// Each endpoint is tied to a partner and subscribed to specific events.
//
// Event types:
//   - lead.created: New credit-scored lead available for lending
//   - lead.updated: Lead status changed (e.g. user's score improved)
//   - payment.received: Subscription payment received from a user
//   - user.churned: User cancelled subscription
//   - campaign.completed: Campaign finished sending all steps
//   - anomaly.detected: Anomaly detected (optional — high-priority partners only)
model WebhookEndpoint {
  id            String   @id @default(cuid())
  partnerId     String
  partner       Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  url           String                            // https://partner.com/webhooks/leads
  secret        String?                           // HMAC signature secret (for verification)
  events        String   @default("[]") @db.Text  // JSON array of event types

  status        String   @default("active")       // active | disabled
  description   String?

  // Stats (updated by delivery job)
  totalSent     Int      @default(0)
  totalSuccess  Int      @default(0)
  totalFailed   Int      @default(0)
  lastSentAt    DateTime?

  // Metadata
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  deliveries    WebhookDelivery[]

  @@index([partnerId, status])
  @@index([status])
}

model WebhookDelivery {
  id              String   @id @default(cuid())
  endpointId      String
  endpoint        WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  eventType       String                             // lead.created | lead.updated | etc.
  payload         String   @db.Text                  // JSON body sent to webhook

  // Delivery status
  status          String   @default("pending")      // pending | success | failed | retrying
  attemptCount    Int      @default(0)
  maxAttempts     Int      @default(3)              // exponential backoff: 1m, 5m, 25m

  // Response info
  responseStatus  Int?                               // HTTP status code (200, 500, etc.)
  responseBody    String?  @db.Text                  // First 1KB of response body (for debugging)
  errorMessage    String?

  // Timing
  firstAttemptAt  DateTime?
  lastAttemptAt   DateTime?
  nextRetryAt     DateTime?                          // when to retry (if failed)
  deliveredAt     DateTime?                          // when successfully delivered

  createdAt       DateTime @default(now())

  @@index([endpointId, status, createdAt])
  @@index([status, nextRetryAt])
  @@index([createdAt])
}

// ==================== REVENUE RECOGNITION (Accrual Accounting) ====================
// Splits each subscription payment into monthly recognition entries.
//
// ACCRUAL ACCOUNTING PRINCIPLE:
//   - Cash received upfront (e.g. ₹2,988 for yearly Pro on Jan 1)
//   - But revenue is "earned" over the subscription period (₹249/month for 12 months)
//   - On Jan 1: Cash=₹2,988, Deferred Revenue=₹2,988 (liability), Recognized=₹0
//   - On Feb 1: Recognized=₹249, Deferred=₹2,739
//   - On Dec 31: Recognized=₹2,988, Deferred=₹0
//
// This table stores one row per subscription per month:
//   - subscriptionId → which subscription this is for
//   - periodStart/End → the month this entry covers
//   - amount → how much revenue is recognized in this period
//   - status → pending (future) | recognized (past) | current (this month)
model RevenueSchedule {
  id              String   @id @default(cuid())
  subscriptionId  String                             // FK to Subscription (not enforced — cross-relation)
  userId          String                             // denormalized for fast queries
  plan            String                             // pro | elite (snapshot)
  amount          Float                              // revenue recognized this period (₹)
  periodStart     DateTime                           // start of the month (e.g. Jan 1 00:00)
  periodEnd       DateTime                           // end of the month (e.g. Jan 31 23:59)
  status          String   @default("pending")       // pending | current | recognized
  recognizedAt    DateTime?                          // when this period was recognized (set by cron)

  // Metadata
  createdAt       DateTime @default(now())

  @@index([status, periodStart])
  @@index([userId, periodStart])
  @@index([subscriptionId])
  @@index([periodStart])
}

// ==================== A/B TESTING (Experiments) ====================
// Create experiments to test variations (e.g. different pricing, UI, features).
// Users are assigned to variants deterministically (same user always gets same variant).
//
// Experiment lifecycle:
//   draft → running → completed | cancelled
//
// Variants:
//   - control: the current/default experience (always 1 control)
//   - treatment: the new experience being tested (1+ treatments)
//
// Metrics tracked:
//   - Conversion: did the user complete a goal? (signup, payment, etc.)
//   - Revenue: how much revenue did the user generate?
//   - Retention: did the user come back after N days?
model Experiment {
  id              String   @id @default(cuid())
  name            String
  description     String?  @db.Text
  status          String   @default("draft")       // draft | running | completed | cancelled

  // What are we testing?
  metric          String                            // conversion | revenue | retention
  metricGoal      String  @default("increase")     // increase | decrease
  targetEvent     String?                           // e.g. 'signup', 'payment', 'day7_retention'

  // Traffic allocation
  trafficPct      Int      @default(100)            // % of users included in experiment (0-100)

  // Variants (stored as JSON: [{ key: 'control', name: 'Default', weight: 50 }, { key: 'treatment_a', name: 'New UI', weight: 50 }])
  variants        String   @default("[]") @db.Text

  // Schedule
  startAt         DateTime?
  endAt           DateTime?

  // Results (filled when experiment completes)
  winnerVariant   String?                           // key of winning variant
  conclusion      String?  @db.Text                 // summary of findings

  // Metadata
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  assignments     ExperimentAssignment[]

  @@index([status, startAt])
}

model ExperimentAssignment {
  id              String   @id @default(cuid())
  experimentId    String
  experiment      Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  userId          String
  variantKey      String                             // 'control' | 'treatment_a' | etc.
  assignedAt      DateTime @default(now())

  // Conversion tracking (filled when user completes the goal)
  convertedAt     DateTime?
  conversionValue Float    @default(0)              // e.g. revenue amount (for revenue metric)

  @@unique([experimentId, userId])                   // one assignment per user per experiment
  @@index([experimentId, variantKey])
  @@index([userId, experimentId])
  @@index([convertedAt])
}

// ==================== COMPETITOR MONITORING ====================
// Track competing apps' pricing, features, and market positioning.
// Admin manually adds competitors and updates their pricing/features periodically.
// Each update is logged as a CompetitorUpdate (timeline of changes).
model Competitor {
  id              String   @id @default(cuid())
  name            String
  website         String?
  description     String?  @db.Text

  // Pricing snapshot (in INR)
  freePrice       String?                          // e.g. "Free" or "₹0"
  proPrice        String?                          // e.g. "₹499/mo"
  elitePrice      String?                          // e.g. "₹999/mo"

  // Feature comparison (JSON: { feature: true/false })
  features        String   @default("{}") @db.Text

  // Market position
  targetMarket    String?                          // e.g. "Small kirana stores"
  usp             String?  @db.Text                // unique selling proposition
  weaknesses      String?  @db.Text                // their weaknesses (our opportunities)

  // Metadata
  status          String   @default("active")      // active | inactive
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  updates         CompetitorUpdate[]

  @@index([status])
}

model CompetitorUpdate {
  id              String   @id @default(cuid())
  competitorId    String
  competitor      Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  // What changed
  field           String                           // e.g. "proPrice", "features", "usp"
  oldValue        String?  @db.Text
  newValue        String?  @db.Text

  note            String?  @db.Text                // admin's note on why this changed
  updatedBy       String?
  createdAt       DateTime @default(now())

  @@index([competitorId, createdAt])
}
